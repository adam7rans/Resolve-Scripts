{
  "name": "cast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "CAST is a local-first transcript-driven video editing and export tool with shader-driven visuals, captions, and clip extraction.",
  "scripts": {
    "dev": "concurrently -k -n API,VITE -c cyan,green \"CAST_PORT=3001 tsx watch server/index.ts\" \"vite\"",
    "server": "CAST_PORT=3001 tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start:app": "CAST_SERVE_STATIC=1 tsx server/index.ts",
    "build:launcher": "node scripts/build-launcher.mjs",
    "install:launcher": "node scripts/install-launcher.mjs"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
}
